# OpenAI-compatible LLM endpoint. Works with OpenAI, Anthropic (compat layer),
# Groq, Together, Mistral, OpenRouter, vLLM, Ollama, LiteLLM proxy, etc.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Used in User-Agent for ORCID/ROR/OpenAlex/Crossref ("polite pool") and as
# the depositor email in generated Crossref XML. Use a real, monitored address.
CONTACT_EMAIL=you@example.org

# GLiNER2 model. Default = fastino/gliner2-large-v1 (340M params, runs CPU on M-series).
# For smaller hosts use fastino/gliner2-base-v1 (205M).
GLINER_MODEL=fastino/gliner2-large-v1

# --- Provider examples (uncomment one) ---
# OpenRouter (any model)
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...
# OPENAI_MODEL=anthropic/claude-sonnet-4-6

# Anthropic via OpenAI-compat
# OPENAI_BASE_URL=https://api.anthropic.com/v1/
# OPENAI_API_KEY=sk-ant-...
# OPENAI_MODEL=claude-sonnet-4-6

# Groq
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_...
# OPENAI_MODEL=llama-3.3-70b-versatile

# Local Ollama
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=qwen2.5:14b

# LiteLLM proxy
# OPENAI_BASE_URL=http://host.docker.internal:4000
# OPENAI_API_KEY=sk-anything
# OPENAI_MODEL=your-routing-name
